use std::collections::HashMap;

struct Solution {}

impl Solution {
    pub fn length_of_longest_substring(s: String) -> i32 {
        let mut sub_string : usize = 0 ;
        let mut sub_string_map : HashMap<u8, usize>= HashMap::with_capacity(s.len());
        let (mut start, mut end ) : (usize, usize)= ( 0, 0);

        while start < s.len() && end < s.len() {
//            println!("{} -> {}", end , s.as_bytes()[end] as char);
            if let Some(&idx) = sub_string_map.get(&s.as_bytes()[end]) {
                if idx >= start {
                if sub_string < end - start {
                    sub_string = end - start 
                }
//                println!("Substring length : {} start : {} end : {} idx : {} char : {}", sub_string, start, end, idx, s.as_bytes()[end] as char);
                start=idx+1;
                }
            }
            sub_string_map.insert(s.as_bytes()[end], end);
//          println!("S:{} E:{}", start, end);
            end+=1;
        } 
//        println!("Substring length : {} start : {} end : {} ", sub_string, start, end);
        if sub_string < end - start {
            sub_string = end - start 
        }


        println!(" Values {:?} ", sub_string_map);

        sub_string as i32
    }
}


